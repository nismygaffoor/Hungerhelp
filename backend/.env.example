MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/hungerhelp
SECRET_KEY=change-me-to-a-random-secret

# Twilio SMS (https://console.twilio.com)
SMS_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+18108880319

# Delivery escalation timing (minutes)
DELIVERY_REMINDER_MINUTES=30
DELIVERY_ESCALATION_MINUTES=120

# Twilio inbound SMS webhook (configure in Twilio console → your number → Messaging)
# Local dev: use ngrok, e.g. https://abc123.ngrok.io/sms/incoming
# SMS_WEBHOOK_URL=https://your-public-api.com/sms/incoming
